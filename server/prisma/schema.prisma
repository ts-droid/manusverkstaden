generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───

enum Plan {
  PROVA
  GRUND
  FORLAG
}

enum ChapterStatus {
  PENDING
  REVIEWING
  REVIEWED
  APPROVED
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── MODELS ───

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  passwordHash         String
  name                 String?
  role                 String        @default("USER")
  plan                 Plan          @default(PROVA)
  isDevAccount         Boolean       @default(false)
  disabled             Boolean       @default(false)
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?
  projects             Project[]
  usageRecords         UsageRecord[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Project {
  id             String    @id @default(cuid())
  title          String
  language       String    @default("sv")
  targetAudience String?
  timePeriod     String?
  perspective    String?
  tense          String?
  tonality       String?
  genres         String[]
  modules        String[]
  transLanguages String[]
  dnaProfile     Json?
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters       Chapter[]
  publishOrders  PublishOrder[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model Chapter {
  id           String        @id @default(cuid())
  number       Int
  title        String
  content      String
  wordCount    Int
  status       ChapterStatus @default(PENDING)
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suggestions  Suggestion[]
  translations Translation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([projectId])
}

model Suggestion {
  id          String           @id @default(cuid())
  type        String
  priority    String
  level       Int
  original    String
  replacement String?
  reason      String
  status      SuggestionStatus @default(PENDING)
  chapterId   String
  chapter     Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([chapterId])
}

model Translation {
  id        String   @id @default(cuid())
  language  String
  content   String
  comments  Json?
  glossary  Json?
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId])
}

model UsageRecord {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // "review", "dna_profile", "develop", "brainstorm", "translate"
  wordCount       Int
  cost            Float    // estimated cost in SEK (user-facing price)
  apiTokensUsed   Int?
  apiInputTokens  Int?     // actual input tokens from Anthropic
  apiOutputTokens Int?     // actual output tokens from Anthropic
  apiCostUsd      Float?   // actual API cost in USD
  model           String?  // model used (e.g. "claude-sonnet-4-20250514")
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

model PlanConfig {
  id                  String @id @default(cuid())
  plan                Plan   @unique
  displayName         String
  priceMonthly        Int    // SEK, 0 for free
  maxChaptersPerMonth Int?   // null = unlimited
  maxWordsPerReview   Int?   // null = unlimited
  includedReviews     Int    @default(0)
  includedWords       Int    @default(0)
  features            Json   @default("{}")
}

// ─── PUBLISHING (prepared for future) ───

enum PublishType {
  EBOOK
  AUDIOBOOK
  PRINT
}

enum PublishStatus {
  DRAFT
  PENDING_PAYMENT
  PROCESSING
  COMPLETED
  FAILED
}

model PublishOrder {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type            PublishType
  status          PublishStatus @default(DRAFT)
  config          Json          // format, layout, cover image, ISBN, etc.
  price           Float?
  stripePaymentId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId])
}

// ─── ADMIN PROMPT MANAGEMENT ───

model PromptConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  content   String
  version   Int      @default(1)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromptHistory {
  id        String   @id @default(cuid())
  key       String
  content   String
  version   Int
  updatedBy String?
  createdAt DateTime @default(now())

  @@index([key])
}
