# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/manusverkstaden

# Anthropic (server-side only – NEVER use VITE_ prefix)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (server-side only – used when codeset is "openai-only" or "dual-provider")
OPENAI_API_KEY=sk-proj-xxxxx

# Default AI codeset (claude-only | openai-only | dual-provider)
# Can be overridden at runtime from admin UI; stored in PromptConfig.
DEFAULT_CODESET=claude-only

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173
